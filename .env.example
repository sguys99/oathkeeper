# Application
APP_NAME="Oath Keeper"
APP_VERSION="0.1.0"
DEBUG=True
ENVIRONMENT=development

# Database
# Docker Compose (default): db is the service name
# Local: change 'db' to 'localhost'
DATABASE_URL=postgresql+asyncpg://oathkeeper:oathkeeper@localhost:5432/oathkeeper

# LLM Configuration
# Provider: openai, claude, or ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Ollama (local SLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Embedding Configuration
# Provider: openai or ollama
EMBEDDING_PROVIDER=openai
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Dimension must match Pinecone index (openai=1536, nomic-embed-text=768)
EMBEDDING_DIMENSIONS=1536

# Prompt Profile (full or compact — use compact for SLM with limited context)
PROMPT_PROFILE=full

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_COMPANY_CONTEXT_INDEX=company-context
PINECONE_PROJECT_HISTORY_INDEX=project-history

# Notion
NOTION_API_KEY=ntn_your_notion_api_key_here
NOTION_DEAL_DB_ID=your_deal_database_id_here
NOTION_DECISION_DB_ID=your_decision_database_id_here
NOTION_PROJECT_HISTORY_DB_ID=your_history_database_id_here

# Slack
SLACK_WEBHOOK_URL=

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO

# CORS (production origins)
CORS_ORIGINS=["http://localhost:3000"]
