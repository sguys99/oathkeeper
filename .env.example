# Application
APP_NAME="Oath Keeper"
APP_VERSION="0.1.0"
DEBUG=True
ENVIRONMENT=development

# Database
# Docker Compose (default): db is the service name
# Local: change 'db' to 'localhost'
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/oathkeeper

# LLM Configuration
# Provider: openai or claude
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_COMPANY_CONTEXT_INDEX=company-context
PINECONE_PROJECT_HISTORY_INDEX=project-history

# Notion
NOTION_API_KEY=ntn_your_notion_api_key_here
NOTION_DEAL_DB_ID=your_deal_database_id_here
NOTION_DECISION_DB_ID=your_decision_database_id_here

# Slack
SLACK_WEBHOOK_URL=
